#!/bin/bash
# AppRun — entry point for the WireGuard GUI AppImage.
#
# This file is executed by the AppImage runtime (type-2 / runtime-fuse3)
# immediately after the squashfs is mounted.  The variable $APPIMAGE points
# to the .AppImage file itself; $APPDIR is the mount-point of the squashfs.
#
# Responsibilities:
#   1. Resolve $HERE (the AppDir root after mounting).
#   2. Prepend $HERE/usr/bin to PATH so that the bundled wg, wg-quick, and
#      any GTK / GLib helpers are found before system copies.
#   3. Set GTK / GDK environment pointers so that GTK-based dialogs (rfd
#      file-picker) locate their typelibs and themes inside the bundle.
#   4. Exec the real binary — never return.
#
# NOTE: "WireGuard" is a registered trademark of Jason A. Donenfeld.
#       This AppImage is an UNOFFICIAL community build and is NOT endorsed
#       by or affiliated with Jason A. Donenfeld or WireGuard developers.

set -euo pipefail

# ── 1. Locate this AppDir ─────────────────────────────────────────────────────
# $APPDIR is set by the AppImage runtime; fall back to the directory containing
# this script for developer testing outside an AppImage.
HERE="${APPDIR:-"$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"}"

# ── 2. PATH — bundle-first so bundled wg / wg-quick are preferred ─────────────
export PATH="${HERE}/usr/bin:${PATH}"

# ── 3. GTK / GLib environment ─────────────────────────────────────────────────
# linuxdeploy-plugin-gtk copies typelibs, themes, and pixbuf loaders into the
# AppDir.  Point the loaders at those copies so GTK widgets (including the rfd
# native file-picker) work on a wide range of host distributions.
export GDK_BACKEND="${GDK_BACKEND:-x11}"

if [ -d "${HERE}/usr/lib/x86_64-linux-gnu/gdk-pixbuf-2.0" ]; then
    export GDK_PIXBUF_MODULEDIR="${HERE}/usr/lib/x86_64-linux-gnu/gdk-pixbuf-2.0/2.10.0/loaders"
    export GDK_PIXBUF_MODULE_FILE="${HERE}/usr/lib/x86_64-linux-gnu/gdk-pixbuf-2.0/2.10.0/loaders.cache"
fi

if [ -d "${HERE}/usr/lib/girepository-1.0" ]; then
    export GI_TYPELIB_PATH="${HERE}/usr/lib/girepository-1.0"
fi

# Allow the GTK theme machinery to find schemas bundled inside the AppDir.
if [ -d "${HERE}/usr/share/glib-2.0/schemas" ]; then
    export GSETTINGS_SCHEMA_DIR="${HERE}/usr/share/glib-2.0/schemas"
fi

# ── 4. Exec the application ───────────────────────────────────────────────────
exec "${HERE}/usr/bin/wireguard-gui" "$@"
